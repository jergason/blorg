#!/usr/bin/env ruby
# Render local OG preview cards for a post.
#
# Usage:
#   bin/og-preview                          # most recent post
#   bin/og-preview <slug-or-path>           # match by slug, filename, or path
#   bin/og-preview --all                    # all posts in one page
#   bin/og-preview --no-build               # skip rebuild, use existing _site
#   bin/og-preview --no-open                # don't auto-open browser

require 'cgi'
require 'fileutils'

ROOT = File.expand_path('..', __dir__)
SITE = File.join(ROOT, '_site')
OUT = File.join(ROOT, '.og-preview.html')

def die(msg)
  warn msg
  exit 1
end

def build!
  Dir.chdir(ROOT) do
    ok = system('bundle', 'exec', 'jekyll', 'build', '--quiet')
    die 'jekyll build failed' unless ok
  end
end

def all_post_htmls
  # permalinks are /:month-:day-:year/:title → _site/MM-DD-YYYY/slug.html
  Dir.glob(File.join(SITE, '*', '*.html')).select do |p|
    p.sub(SITE + '/', '') =~ %r{\A\d{2}-\d{2}-\d{4}/[^/]+\.html\z}
  end
end

def find_post_html(query)
  htmls = all_post_htmls
  return htmls.max_by { |p| File.mtime(p) } if query.nil?
  q = query.sub(/\.md\z/, '').downcase
  match = htmls.find { |p| p.downcase.include?(q) }
  die "no post matching #{query.inspect}" unless match
  match
end

def extract_meta(html)
  meta = {}
  html.scan(/<meta\s+[^>]+>/i).each do |tag|
    key = tag[/(?:property|name)\s*=\s*["']([^"']+)["']/i, 1]
    val = tag[/content\s*=\s*["']([^"']*)["']/i, 1]
    next unless key && val
    meta[key.downcase] ||= CGI.unescapeHTML(val)
  end
  title = html[%r{<title>([^<]*)</title>}i, 1]
  meta['__title__'] = CGI.unescapeHTML(title.strip) if title
  meta['__canonical__'] = html[/<link\s+rel=["']canonical["']\s+href=["']([^"']+)["']/i, 1]
  meta
end

def card_html(meta, source_path)
  title = meta['og:title'] || meta['twitter:title'] || meta['__title__'] || '(no title)'
  desc = meta['og:description'] || meta['twitter:description'] || meta['description'] || ''
  image = meta['og:image'] || meta['twitter:image']
  url = meta['og:url'] || meta['__canonical__'] || ''
  domain = url[%r{//([^/]+)}, 1] || 'jamison.dance'
  card_type = meta['twitter:card'] || 'summary_large_image'

  img_tag = if image
              local = image.sub(%r{\Ahttps?://[^/]+}, '')
              local_path = File.join(SITE, local.sub(%r{\A/}, ''))
              src = File.file?(local_path) ? "file://#{local_path}" : image
              %(<img src="#{CGI.escapeHTML(src)}" alt="">)
            else
              '<div class="no-img">no image</div>'
            end

  <<~HTML
    <section class="post" data-source="#{CGI.escapeHTML(source_path)}">
      <h2>#{CGI.escapeHTML(title)} <small>#{CGI.escapeHTML(source_path)}</small></h2>
      <div class="cards">
        <figure class="card x">
          <figcaption>X / Twitter (#{CGI.escapeHTML(card_type)})</figcaption>
          <div class="x-card">
            #{img_tag}
            <div class="x-meta">
              <div class="x-domain">#{CGI.escapeHTML(domain)}</div>
              <div class="x-title">#{CGI.escapeHTML(title)}</div>
              <div class="x-desc">#{CGI.escapeHTML(desc)}</div>
            </div>
          </div>
        </figure>

        <figure class="card slack">
          <figcaption>Slack unfurl</figcaption>
          <div class="slack-card">
            <div class="slack-bar"></div>
            <div class="slack-body">
              <div class="slack-domain">#{CGI.escapeHTML(domain)}</div>
              <div class="slack-title">#{CGI.escapeHTML(title)}</div>
              <div class="slack-desc">#{CGI.escapeHTML(desc)}</div>
              #{img_tag}
            </div>
          </div>
        </figure>

        <figure class="card imsg">
          <figcaption>iMessage / Discord-ish</figcaption>
          <div class="imsg-card">
            #{img_tag}
            <div class="imsg-meta">
              <div class="imsg-title">#{CGI.escapeHTML(title)}</div>
              <div class="imsg-domain">#{CGI.escapeHTML(domain)}</div>
            </div>
          </div>
        </figure>
      </div>

      <details>
        <summary>raw meta tags (#{meta.size - 2})</summary>
        <pre>#{CGI.escapeHTML(meta.reject { |k, _| k.start_with?('__') }.map { |k, v| "#{k} = #{v}" }.join("\n"))}</pre>
      </details>
    </section>
  HTML
end

def page(sections)
  <<~HTML
    <!doctype html>
    <html><head><meta charset="utf-8"><title>OG preview</title>
    <style>
      body { font: 14px/1.4 -apple-system, system-ui, sans-serif; background: #f4f4f5; color: #18181b; margin: 0; padding: 24px; }
      .post { background: white; border: 1px solid #e4e4e7; border-radius: 8px; padding: 20px; margin-bottom: 24px; }
      .post h2 { margin: 0 0 16px; font-size: 18px; }
      .post h2 small { font-weight: 400; color: #71717a; font-size: 12px; margin-left: 8px; }
      .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap: 20px; }
      figure { margin: 0; }
      figcaption { font-size: 12px; color: #71717a; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em; }
      .card img { display: block; width: 100%; height: auto; }
      .no-img { background: #fee2e2; color: #991b1b; padding: 40px; text-align: center; font-weight: 600; }

      /* X / Twitter large image */
      .x-card { border: 1px solid #e4e4e7; border-radius: 16px; overflow: hidden; max-width: 520px; background: white; }
      .x-card img { aspect-ratio: 1.91/1; object-fit: cover; }
      .x-meta { padding: 10px 14px; }
      .x-domain { color: #536471; font-size: 13px; }
      .x-title { font-weight: 500; margin-top: 2px; }
      .x-desc { color: #536471; font-size: 13px; margin-top: 2px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

      /* Slack */
      .slack-card { display: flex; max-width: 520px; }
      .slack-bar { width: 4px; background: #dddddd; border-radius: 2px; margin-right: 12px; }
      .slack-body { flex: 1; }
      .slack-domain { font-size: 13px; color: #616061; }
      .slack-title { color: #1264a3; font-weight: 700; margin-top: 2px; }
      .slack-desc { font-size: 14px; color: #1d1c1d; margin: 6px 0; }
      .slack-card img { max-width: 360px; border-radius: 8px; margin-top: 8px; }

      /* iMessage-ish */
      .imsg-card { border-radius: 16px; overflow: hidden; max-width: 360px; background: #f2f2f7; border: 1px solid #d1d1d6; }
      .imsg-card img { aspect-ratio: 1.91/1; object-fit: cover; }
      .imsg-meta { padding: 10px 14px; }
      .imsg-title { font-weight: 600; font-size: 14px; }
      .imsg-domain { font-size: 12px; color: #8e8e93; margin-top: 2px; }

      details { margin-top: 16px; }
      details pre { background: #f4f4f5; padding: 12px; border-radius: 6px; overflow-x: auto; font-size: 12px; }
      h1 { font-size: 14px; color: #71717a; font-weight: 500; margin: 0 0 16px; }
    </style>
    </head><body>
    <h1>OG preview — generated #{Time.now.strftime('%Y-%m-%d %H:%M')}</h1>
    #{sections.join("\n")}
    </body></html>
  HTML
end

# ---- main ----
args = ARGV.dup
do_build = !args.delete('--no-build')
do_open = !args.delete('--no-open')
all = !!args.delete('--all')
query = args.first

build! if do_build
die "no _site dir at #{SITE} (run jekyll build first or drop --no-build)" unless Dir.exist?(SITE)

targets = all ? all_post_htmls.sort.reverse : [find_post_html(query)]
sections = targets.map do |path|
  meta = extract_meta(File.read(path))
  rel = path.sub(SITE + '/', '')
  card_html(meta, rel)
end

File.write(OUT, page(sections))
puts "wrote #{OUT} (#{targets.length} post#{'s' if targets.length != 1})"
system('open', OUT) if do_open && RUBY_PLATFORM =~ /darwin/
